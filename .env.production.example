APP_NAME="Agenda de Missões"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Banco de dados: SQLite (arquivo único, funciona offline).
# Deixe DB_DATABASE em branco/comentado para usar database/database.sqlite
DB_CONNECTION=sqlite
# DB_DATABASE=/caminho/absoluto/para/database/database.sqlite

# Modo WAL: melhora leituras concorrentes (o painel usa wire:poll)
# sem travar escritas. Os valores abaixo já são o PADRÃO em config/database.php
# — só descomente se precisar sobrescrever. WAL cria os arquivos auxiliares
# database.sqlite-wal / -shm (efêmeros; o backup via sqlite3 .backup os trata).
# DB_JOURNAL_MODE=WAL
# DB_SYNCHRONOUS=NORMAL
# DB_BUSY_TIMEOUT=5000

# Primeiro acesso: o bundle já semeia um admin inicial (usuário "admin" com
# senha padrão). TROQUE a senha no deploy com 'php artisan app:create-user'
# (ver DEPLOY.md) — não há recuperação de senha automática (rede offline).

# Sessão e cache em arquivo — não exigem tabelas extras.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log
MEMCACHED_HOST=127.0.0.1
